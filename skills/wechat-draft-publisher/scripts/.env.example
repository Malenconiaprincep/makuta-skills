WECHAT_APPID=your_appid
WECHAT_APPSECRET=your_appsecret
WECHAT_AUTHOR=
WECHAT_DIGEST=
WECHAT_CONTENT_SOURCE_URL=
WECHAT_THUMB_MEDIA_ID=your_thumb_media_id
WECHAT_SAFE_IMAGE_DOMAIN=https://your-wechat-safe-domain.example.com/image
# HTML style for article body: wechat | minimal | calm
WECHAT_HTML_THEME=wechat
# 1 = 将 ul/ol 转为缩进 <p>（公众号里少出现「空列表项」）；0 = 保留原生 <ul>/<li>
WECHAT_FLATTEN_LISTS=1
